{
  "name": "nuxt-fsd-boilerplate",
  "private": true,
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "generate": "nuxt generate",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:style": "stylelint \"**/*.{css,vue}\"",
    "lint:style:fix": "stylelint \"**/*.{css,vue}\" --fix",
    "lint:all": "yarn lint && yarn lint:style",
    "lint:all:fix": "yarn lint:fix && yarn lint:style:fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.9.0",
    "pinia": "^2.3.0",
    "vue": "latest",
    "vue-router": "latest"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.0.0",
    "@nuxt/test-utils": "^3.17.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^9.17.0",
    "happy-dom": "^16.6.0",
    "nuxt": "^3.16.0",
    "postcss-html": "^1.8.1",
    "stylelint": "^16.12.0",
    "stylelint-config-standard": "^37.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "stylelint-order": "^6.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.2.0"
  }
}
